# Copy this file to .kamal/deploy.env, fill in your deployment identifiers,
# then run `set -a; source .kamal/deploy.env; set +a` before Kamal commands.
KAMAL_SERVICE=thinkroom
KAMAL_IMAGE=your-github-user/thinkroom
KAMAL_HOSTS=your-server.example.com
KAMAL_PROXY_HOSTS=thinkroom.example.com
KAMAL_REGISTRY_SERVER=ghcr.io
KAMAL_REGISTRY_USERNAME=your-github-user
KAMAL_STORAGE_VOLUME=thinkroom_storage
KAMAL_BUILDER_ARCH=amd64
KAMAL_SSH_USER=root

# Optional: build on a remote Docker host instead of the local machine.
# KAMAL_BUILDER_REMOTE=ssh://root@your-server.example.com
